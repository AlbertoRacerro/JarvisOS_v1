{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FastSecretarySoftProposalV0_1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_short",
    "project_bucket",
    "primary_domain",
    "domain_tags",
    "storage_relevance",
    "usefulness_for_future_review",
    "possible_memory_card_type",
    "soft_reason_code",
    "brief_rationale",
    "suggested_followup_question",
    "soft_uncertain_fields"
  ],
  "properties": {
    "summary_short": {
      "type": "string",
      "maxLength": 240,
      "description": "Short local advisory summary. Do not copy exact credentials."
    },
    "project_bucket": {
      "type": "string",
      "enum": [
        "jarvisos",
        "bluerev",
        "coursework",
        "personal",
        "general",
        "unknown"
      ],
      "description": "Advisory project label only."
    },
    "primary_domain": {
      "type": "string",
      "enum": [
        "memory",
        "software",
        "retrieval",
        "local_ai",
        "modeling",
        "bioprocess",
        "reactor_design",
        "coursework",
        "personal",
        "security",
        "general",
        "unknown"
      ],
      "description": "Advisory domain label only."
    },
    "domain_tags": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "type": "string",
        "maxLength": 32
      },
      "description": "Advisory topical tags."
    },
    "storage_relevance": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high"
      ],
      "description": "Advisory usefulness estimate, not memory-write authority."
    },
    "usefulness_for_future_review": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high"
      ],
      "description": "Advisory usefulness for later human review."
    },
    "possible_memory_card_type": {
      "type": "string",
      "enum": [
        "none",
        "knowledge_card",
        "memory_card",
        "decision_card",
        "assumption_card",
        "evidence_card",
        "source_card",
        "task_card",
        "unknown"
      ],
      "description": "Candidate card type only; not promotion."
    },
    "soft_reason_code": {
      "type": "string",
      "enum": [
        "contextual_summary",
        "memory_candidate",
        "decision_candidate",
        "assumption_candidate",
        "evidence_candidate",
        "source_candidate",
        "clarification_context",
        "low_value",
        "unknown"
      ],
      "description": "Compact soft-review reason. Do not encode hard-gate authority here."
    },
    "brief_rationale": {
      "type": "string",
      "maxLength": 360,
      "description": "Short reviewer-facing rationale. No permission or runtime approval."
    },
    "suggested_followup_question": {
      "type": "string",
      "maxLength": 240,
      "description": "Optional follow-up question; empty string when none."
    },
    "soft_uncertain_fields": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "maxLength": 48
      },
      "description": "Soft fields that need human review."
    }
  }
}
