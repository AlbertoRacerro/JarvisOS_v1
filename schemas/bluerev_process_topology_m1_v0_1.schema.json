{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvisos.local/schemas/bluerev_process_topology_m1_v0_1.schema.json",
  "title": "BlueRev process topology M1 manifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "model_id", "model_label", "input_sha256", "topology", "summary", "limitations", "topology_digest"],
  "properties": {
    "schema_version": {"const": "0.1"},
    "model_id": {"const": "bluerev_process_topology_m1_v0"},
    "model_label": {"const": "bluerev-process-topology-m1-v0.1.0"},
    "input_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "topology_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["loop_count", "parallel_path_count", "branch_template_order", "representative_path_order", "components"],
      "properties": {
        "loop_count": {"const": 1},
        "parallel_path_count": {"type": "integer", "minimum": 1, "maximum": 12},
        "branch_template_order": {
          "const": ["branch_illuminated_straight_run", "branch_bend_group", "branch_dark_straight_run"]
        },
        "representative_path_order": {
          "const": ["common_supply_run", "split_manifold", "branch_template", "merge_manifold", "common_return_run"]
        },
        "components": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {"type": "object", "required": ["id", "kind", "multiplicity"], "properties": {"id": {"type": "string"}, "kind": {"type": "string"}, "multiplicity": {"type": "integer", "minimum": 1}}, "additionalProperties": true}
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["installed_tube_length_total_m", "representative_hydraulic_path_length_m", "total_liquid_inventory_m3", "total_circulation_flow_rate_m3_s", "total_pressure_loss_pa"],
      "properties": {
        "installed_tube_length_total_m": {"type": "number", "minimum": 0},
        "representative_hydraulic_path_length_m": {"type": "number", "exclusiveMinimum": 0},
        "total_liquid_inventory_m3": {"type": "number", "minimum": 0},
        "total_circulation_flow_rate_m3_s": {"type": "number", "exclusiveMinimum": 0},
        "total_pressure_loss_pa": {"type": "number", "minimum": 0}
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"},
      "uniqueItems": true
    }
  }
}
