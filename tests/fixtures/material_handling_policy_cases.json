{
  "_meta": {
    "purpose": "Stage 5-PRE contract fixtures for material objects. NOT wired to runtime tests yet.",
    "semantics": "Each case is a material object with its target sensitivity class and the per-action policy expected after Stage 5 consolidation. Documents the future boundary so ingestion/retrieval/tool/MCP layers cannot bypass it.",
    "policy_values": ["allow", "deny", "redacted_only", "confirm_first", "inherit_max"]
  },
  "cases": [
    {
