      "retrieval_policy": "deny",
      "egress_policy": "deny",
      "tool_policy": "deny",
      "provider_policy": "blocked_requires_user_review",
      "confirmation_required": true,
      "note": "CURRENT: history scan returns None (included). TARGET: excluded."
    },
    {
