      "object_type": "chat_message",
      "target_class": "S0_PUBLIC",
      "storage_policy": "allow",
      "retrieval_policy": "allow",
      "egress_policy": "allow",
      "tool_policy": "allow",
      "provider_policy": "local_preferred",
      "confirmation_required": false
    },
    {
