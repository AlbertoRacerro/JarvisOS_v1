{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvisos.local/schemas/engineering-microtopic-v2.1.schema.json",
  "title": "Engineering Microtopic Record v2.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "identity",
    "classification",
    "source_evidence",
    "knowledge",
    "verification",
    "assessment",
    "jarvis",
    "governance"
  ],
  "properties": {
    "schema_version": {"const": "2.1.0"},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["microtopic_id", "title", "canonical_name", "aliases", "primary_record_type", "record_types", "granularity", "parent_ids"],
      "properties": {
        "microtopic_id": {"type": "string", "minLength": 3},
        "title": {"type": "string", "minLength": 3},
        "canonical_name": {"type": "string", "minLength": 3},
        "aliases": {"type": "array", "items": {"type": "string"}},
        "primary_record_type": {"type": "string"},
        "record_types": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "granularity": {"enum": ["atomic", "compound", "bridge"]},
        "parent_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["course", "domain", "subdomain", "language", "tags"],
      "properties": {
        "course": {"type": "string"},
        "domain": {"type": "string"},
        "subdomain": {"type": "string"},
        "language": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "source_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "source_file", "source_sha256", "locator", "authority", "evidence_type", "supports_fields"],
        "properties": {
          "source_id": {"type": "string"},
          "source_file": {"type": "string"},
          "source_sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"},
          "locator": {"type": "string"},
          "authority": {"type": "string"},
          "evidence_type": {"type": "string"},
          "supports_fields": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        }
      }
    },
    "knowledge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "physical_meaning", "inputs", "outputs", "assumptions", "validity", "invalidity", "equations", "variables", "procedure", "relations"],
      "properties": {
        "summary": {"type": "string", "minLength": 10},
        "physical_meaning": {"type": "string", "minLength": 10},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "outputs": {"type": "array", "items": {"type": "string"}},
        "assumptions": {"type": "array", "items": {"type": "string"}},
        "validity": {"type": "array", "items": {"type": "string"}},
        "invalidity": {"type": "array", "items": {"type": "string"}},
        "equations": {"type": "array", "items": {"type": "object"}},
        "variables": {"type": "array", "items": {"type": "object"}},
        "procedure": {"type": "array", "items": {"type": "string"}},
        "relations": {"type": "array", "items": {"type": "object"}}
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "methods", "deterministic_checks", "confidence", "limitations", "knowledge_exportable"],
      "properties": {
        "status": {"enum": ["unreviewed", "source_supported", "dimensionally_checked", "numerically_reproduced", "cross_source_verified", "expert_verified"]},
        "methods": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "deterministic_checks": {"type": "array", "items": {"type": "string"}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "limitations": {"type": "array", "items": {"type": "string"}},
        "knowledge_exportable": {"type": "boolean"}
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["benchmark_eligible", "task_types", "benchmark_readiness", "contamination_class"],
      "properties": {
        "benchmark_eligible": {"type": "boolean"},
        "task_types": {"type": "array", "items": {"type": "string"}},
        "benchmark_readiness": {"enum": ["not_candidate", "candidate", "development", "holdout_ready"]},
        "contamination_class": {"type": "string"}
      }
    },
    "jarvis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability_eligible", "capability_candidates", "deterministic_core", "ai_role", "required_tools"],
      "properties": {
        "capability_eligible": {"type": "boolean"},
        "capability_candidates": {"type": "array", "items": {"type": "string"}},
        "deterministic_core": {"type": "array", "items": {"type": "string"}},
        "ai_role": {"type": "array", "items": {"type": "string"}},
        "required_tools": {"type": "array", "items": {"type": "string"}}
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lifecycle_status", "visibility", "retention_policy", "created_utc", "updated_utc"],
      "properties": {
        "lifecycle_status": {"enum": ["extracted", "reviewed", "verified", "benchmark_ready", "deprecated"]},
        "visibility": {"type": "string"},
        "retention_policy": {"const": "canonical_verified_knowledge_only"},
        "created_utc": {"type": "string"},
        "updated_utc": {"type": "string"}
      }
    }
  }
}
